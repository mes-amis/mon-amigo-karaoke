<section class="card">
  <h1>Pick your karaoke name</h1>
  <p class="muted">You'll use this to pick a song and take your turn.</p>
  <form method="post" action="/join" class="form">
    <label for="name">Name</label>
    <input id="name" name="name" type="text" maxlength="40" autofocus required
           autocomplete="off" placeholder="e.g. Craig">
    <button type="submit" class="primary">Join the queue</button>
  </form>
</section>
