#!/usr/bin/env python3
"""Launcher that auto-uses the project's .venv if one exists."""

import os
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.dirname(HERE)

# If bin/setup has created a .venv and we're not already running inside it,
# re-exec under that interpreter so dependencies are visible without the user
# having to `source .venv/bin/activate` first.
#
# Detect "am I in the venv" via sys.prefix (which venv startup rewrites),
# not sys.executable — macOS venv pythons are symlinks to the underlying
# framework interpreter, so comparing realpaths of executables gives a
# false "already inside" when we're actually running under system Python.
_VENV = os.path.join(ROOT, ".venv")
_VENV_PY = os.path.join(_VENV, "bin", "python3")
_in_venv = os.path.realpath(sys.prefix) == os.path.realpath(_VENV)
if os.path.isfile(_VENV_PY) and not _in_venv:
    os.execv(_VENV_PY, [_VENV_PY, __file__, *sys.argv[1:]])

sys.path.insert(0, os.path.join(ROOT, "src"))

from karaoke.cli import main

if __name__ == "__main__":
    main()
